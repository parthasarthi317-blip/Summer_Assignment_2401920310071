/*
Problem: Maximum Depth of Binary Tree

Time Complexity: O(n)
Space Complexity: O(h)
*/

class Solution {
    public int maxDepth(TreeNode root) {
        if(root == null) {
            return 0;
        }
        return 1 + Math.max(maxDepth(root.left),
                            maxDepth(root.right));
    }
}