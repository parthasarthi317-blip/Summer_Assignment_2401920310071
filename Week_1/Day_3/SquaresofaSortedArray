/*
Problem: Squares of a Sorted Array

Time Complexity: O(n log n)
Space Complexity: O(1)
*/
class Solution {
    public int[] sortedSquares(int[] nums) {
        for(int i = 0; i < nums.length; i++) {
            nums[i] = nums[i] * nums[i];
        }
        Arrays.sort(nums);
        return nums;
    }
}